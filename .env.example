# ----------------------------------------------------------------------------
# Database (Supabase Postgres). For local dev you can use the docker compose
# Postgres (see docker-compose.yml) or a Supabase project connection string.
# ----------------------------------------------------------------------------
# Local dev (docker-compose.yml maps Postgres to host port 5433):
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/freeway?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5433/freeway?schema=public"
#
# Self-hosted (docker-compose.prod.yml) — point at the compose service:
#   DATABASE_URL="postgresql://postgres:postgres@postgres:5432/freeway?schema=public"
#   DIRECT_URL="postgresql://postgres:postgres@postgres:5432/freeway?schema=public"
#
# Supabase — DATABASE_URL = pooled (port 6543, add &pgbouncer=true),
#            DIRECT_URL   = direct (port 5432, used by migrations):
#   DATABASE_URL="postgresql://postgres.PROJECT:PW@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
#   DIRECT_URL="postgresql://postgres.PROJECT:PW@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ----------------------------------------------------------------------------
# Supabase (auth + storage). Optional for the MVP — the app falls back to a
# cookie-based demo session when these are not set.
# ----------------------------------------------------------------------------
# When these are set, the app uses real Supabase email/password auth.
# When unset, it falls back to a cookie-based demo session.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Service role key enables uploading generated videos to Supabase Storage.
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_VIDEO_BUCKET="videos"

# ----------------------------------------------------------------------------
# OpenAI. If unset, the generation pipeline uses a deterministic MOCK provider
# so the whole app still works end-to-end offline.
# ----------------------------------------------------------------------------
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
OPENAI_IMAGE_MODEL="gpt-image-2"

# ----------------------------------------------------------------------------
# Redis / BullMQ. If REDIS_URL is unset, the pipeline runs INLINE (no worker
# needed) so you can demo without Redis. Set it to use real background queues.
# ----------------------------------------------------------------------------
REDIS_URL=""

# ----------------------------------------------------------------------------
# SERP API for stock images (https://serpapi.com). Optional fallback when DALL·E
# generation fails or OPENAI_API_KEY is unset.
# ----------------------------------------------------------------------------
SERPAPI_KEY=""

# ----------------------------------------------------------------------------
# Manim video generation. Set MANIM_ENABLED=1 and have `manim` on PATH to
# render real explainer videos; otherwise a themed animated scene is shown.
# MathTex scenes need LaTeX — see README § Video (Manim) (basictex + tlmgr).
# ----------------------------------------------------------------------------
MANIM_ENABLED="0"
MANIM_BIN="manim"

# ----------------------------------------------------------------------------
# ElevenLabs text-to-speech for video narration voiceover.
# ----------------------------------------------------------------------------
ELEVENLABS_API_KEY=""
ELEVENLABS_VOICE_ID="21m00Tcm4TlvDq8ikWAM"
ELEVENLABS_MODEL="eleven_multilingual_v2"
